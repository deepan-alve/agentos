# --- agentos-api ---

# Port this service listens on.
AGENTOS_API_PORT=4100
# LAN IP surfaced to the phone for built apps (auto-detected if unset).
# AGENTOS_LAN_HOST=192.168.1.50

# Paperclip control plane (github.com/paperclipai/paperclip), running locally.
PAPERCLIP_BASE=http://127.0.0.1:3100/api
# Where Paperclip stores instances + templates.
PAPERCLIP_HOME=/path/to/.paperclip
# Optional: override the templates dir directly.
# TEMPLATES_ROOT=/path/to/.paperclip/templates

# Paperclip company + goal the builds are filed under.
PAPERCLIP_COMPANY_ID=your-company-uuid
PAPERCLIP_GOAL_ID=your-goal-uuid

# Agent pools: comma-separated "id:name" pairs.
VELA_POOL=agent-uuid-1:Vela-2,agent-uuid-2:Vela-3
HELIX_POOL=agent-uuid:Helix

# Vertex AI for the prompt classifier.
VERTEX_SA_PATH=/path/to/vertex/service-account.json
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_CLASSIFIER_MODEL=gemini-2.5-flash-lite

# Deployed-app port range.
PORT_MIN=5001
PORT_MAX=5999

# Optional: path to Appwrite admin creds for Tier-3 (Appwrite) builds.
# APPWRITE_CREDS_PATH=/path/to/.agentos/appwrite-creds.json
